#!/usr/bin/env python3
"""
tapeworm — one command for the full tape pipeline.

  ./tapeworm mount <folder>    Mount as folder + debug UI
  ./tapeworm format            Format tape
  ./tapeworm ls                List files
  ./tapeworm read <n> [out]    Read file
  ./tapeworm write <l> [n]     Write file
"""

import os, sys, struct, time, select, subprocess, signal, atexit, threading
import struct as st

HERE = os.path.dirname(os.path.abspath(__file__))
FW_BIN = os.path.join(HERE, "cpp", "firmware", "run_firmware")
TAPE_FILE = "/tmp/tapewormfs_raw.tape"

# Build firmware
if not os.path.exists(FW_BIN):
    fw_dir = os.path.join(HERE, "cpp", "firmware")
    subprocess.check_call(
        f"cd '{fw_dir}' && g++ -std=c++17 -o run_firmware -x c++ - <<< "
        f'#include "firmware.hpp"\n'
        f'int main() {{ tapefs::firmware::Firmware fw; fw.run(); return 0; }}'
        f' firmware.cpp modem_encoder.cpp modem_decoder.cpp '
        f'tape_medium.cpp tape_deck.cpp motor.cpp esp32_hal.cpp '
        f'-lpthread -I.', shell=True)

# ---- Packet protocol --------------------------------------------- #
START = 0xFE
def crc16(d):
    c = 0
    for b in d:
        c ^= b << 8
        for _ in range(8):
            if c & 0x8000: c = (c << 1) ^ 0x8005
            else: c <<= 1
            c &= 0xFFFF
    return c

def esc(d):
    o = bytearray()
    for b in d:
        if b == 0xFE: o.extend([0xFD, 0x01])
        elif b == 0xFD: o.extend([0xFD, 0x02])
        else: o.append(b)
    return bytes(o)

def unesc(d):
    o = bytearray(); i = 0
    while i < len(d):
        if d[i] == 0xFD and i+1 < len(d):
            if d[i+1] == 0x01: o.append(0xFE)
            elif d[i+1] == 0x02: o.append(0xFD)
            i += 2
        else: o.append(d[i]); i += 1
    return bytes(o)

def enc(c, p=b''):
    inner = st.pack('<H', 1+len(p)+2) + bytes([c]) + p
    crc = crc16(inner) & 0xFFFF
    inner += st.pack('<H', crc)
    return bytes([START]) + esc(inner)

def dec(data):
    if not data or data[0] != START: return None
    inner = unesc(data[1:])
    if len(inner) < 5: return None
    L = st.unpack_from('<H', inner, 0)[0]
    if len(inner) < 2+L: return None
    cmd = inner[2]
    payload = inner[3:3+L-3]
    return {'cmd': cmd, 'payload': payload}

# ---- Firmware process -------------------------------------------- #
fw = None

def fw_start():
    global fw
    if fw and fw.poll() is None: return
    fw = subprocess.Popen([FW_BIN], stdin=subprocess.PIPE,
                          stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    time.sleep(0.3)
    atexit.register(fw_stop)

def fw_stop():
    global fw
    if fw:
        try: fw.terminate(); fw.wait(timeout=2)
        except: fw.kill()
        fw = None

def send(c, p=b''):
    fw_start(); fw.stdin.write(enc(c, p)); fw.stdin.flush()

def recv(e, t=5.0):
    buf = b''; dl = time.monotonic() + t
    while time.monotonic() < dl:
        r,_,_ = select.select([fw.stdout],[],[],0.1)
        if r:
            c = fw.stdout.read1(4096)
            if not c: return None
            buf += c
        i = buf.find(bytes([START]))
        if i < 0: continue
        buf = buf[i:]
        pk = dec(buf)
        if pk is None: buf = buf[1:]; continue
        if pk['cmd'] == e: return pk['payload']
        buf = b''
    return None

def wb(block_bytes):
    send(0x05, block_bytes)
    r = recv(0x85)
    if r and r[0] == 0x00:
        send(0x07); recv(0x87)
        return True
    return False

def rb():
    send(0x06)
    r = recv(0x86, 120.0)
    if r and len(r) > 5: return r[0:1] + r[1:-4]
    return None

def sk(n):
    p = st.pack('<III', n, 0, n*1000) + bytes([0, 255])
    send(0x03, p); r = recv(0x83)
    return r and r[0] == 0x00

# ---- Read waveform from tape file -------------------------------- #
def read_waveform(count=320):
    """Read last N float32 samples from the tape file."""
    if not os.path.exists(TAPE_FILE): return [0.0]*count
    with open(TAPE_FILE, 'rb') as f:
        f.seek(0, 2)  # end
        sz = f.tell()
        samples = min(count, sz // 4)
        f.seek(max(0, sz - samples*4))
        raw = f.read(samples*4)
    return [st.unpack_from('<f', raw, i)[0] for i in range(0, len(raw), 4)]

# ---- Commands ----------------------------------------------------- #
def cmd_format():
    from tapefs import Block, BlockType, serialise, Directory
    d = serialise(Block(BlockType.DIRECTORY, data=Directory().serialise()))
    e = serialise(Block(BlockType.EOT, seq_no=1))
    if wb(d.bytes) and wb(e.bytes): print("  Tape formatted")
    else: print("  Format failed")
    fw_stop()

def cmd_ls():
    from tapefs import deserialise, RawBlock, Directory
    if not sk(0): return print("  (empty tape)")
    rd = rb()
    if not rd: return print("  (empty tape)")
    b, e = deserialise(RawBlock(bytes=rd))
    if e or b.type != 2: return print("  (empty tape)")
    d = Directory.deserialise(b.data)
    if not d.entries: return print("  (empty tape)")
    for e in d.entries: print(f"  {e.filename:<20} {e.file_size:>8} B")
    fw_stop()

def cmd_read(name, out=None):
    from tapefs import Filesystem, RawBlock
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)
    data, err = fs.read_file(name)
    if err: return print(f"  '{name}' not found")
    if out:
        with open(out, 'wb') as f: f.write(data)
        print(f"  Wrote {len(data)} B to {out}")
    else: sys.stdout.buffer.write(data)
    fw_stop()

def cmd_write(local, tapename=None):
    tapename = tapename or os.path.basename(local)
    with open(local, 'rb') as f: data = f.read()
    from tapefs import Filesystem, RawBlock
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)
    err = fs.write_file(tapename, data)
    if err: return print(f"  Write failed: {err}")
    print(f"  Wrote '{tapename}' ({len(data)} B)")
    fw_stop()

def cmd_mount(mountpoint):
    """Mount FUSE folder + show live GUI debug window."""
    try:
        import fuse
    except ImportError:
        print("Need fusepy: pip install fusepy")
        return

    fw_start()
    from tapefs import Filesystem, RawBlock
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)

    # ---- tkinter debug window ----------------------------------- #
    import tkinter as tk
    from tkinter import ttk

    root = tk.Tk()
    root.title("TapewormFS — Live Debug")
    root.geometry("900x600")
    root.configure(bg='#1a1a2e')

    # Colors
    BG      = '#1a1a2e'
    FG      = '#e0e0e0'
    ACCENT  = '#00d4aa'
    WARN    = '#ff6b6b'
    WAVE_BG = '#16213e'

    # ---- Waveform canvas ---------------------------------------- #
    wave_frame = tk.Frame(root, bg=BG)
    wave_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)

    wave_canvas = tk.Canvas(wave_frame, bg=WAVE_BG, height=200,
                            highlightthickness=1, highlightbackground='#333')
    wave_canvas.pack(fill=tk.BOTH, expand=True)

    # ---- Status bar (tape position) ------------------------------ #
    tape_frame = tk.Frame(root, bg=BG, height=40)
    tape_frame.pack(fill=tk.X, padx=10, pady=2)

    tape_canvas = tk.Canvas(tape_frame, bg='#0f3460', height=30,
                            highlightthickness=0)
    tape_canvas.pack(fill=tk.X)

    # ---- Info row (motor, modem, packets) ------------------------ #
    info_frame = tk.Frame(root, bg=BG)
    info_frame.pack(fill=tk.X, padx=10, pady=5)

    motor_lbl = tk.Label(info_frame, text="MOTOR: ■ STOPPED",
                         fg=WARN, bg=BG, font=('Consolas', 11, 'bold'))
    motor_lbl.pack(side=tk.LEFT, padx=10)

    modem_lbl = tk.Label(info_frame, text="MODEM: IDLE",
                         fg=ACCENT, bg=BG, font=('Consolas', 11))
    modem_lbl.pack(side=tk.LEFT, padx=10)

    pkt_lbl = tk.Label(info_frame, text="PACKETS: 0",
                       fg=FG, bg=BG, font=('Consolas', 11))
    pkt_lbl.pack(side=tk.LEFT, padx=10)

    pos_lbl = tk.Label(info_frame, text="POS: 0 mm",
                       fg=FG, bg=BG, font=('Consolas', 11))
    pos_lbl.pack(side=tk.RIGHT, padx=10)

    tape_size_lbl = tk.Label(info_frame, text="TAPE: 0 KB",
                              fg=FG, bg=BG, font=('Consolas', 11))
    tape_size_lbl.pack(side=tk.RIGHT, padx=10)

    # ---- File list ----------------------------------------------- #
    file_frame = tk.Frame(root, bg=BG)
    file_frame.pack(fill=tk.X, padx=10, pady=5)

    file_listbox = tk.Listbox(file_frame, bg='#0f3460', fg=FG,
                              font=('Consolas', 10), height=6,
                              selectbackground=ACCENT, borderwidth=0)
    file_listbox.pack(fill=tk.X)

    # ---- Update functions ---------------------------------------- #
    packet_count = [0]
    sample_buffer = [0.0]*500

    def update_waveform():
        # Read samples from tape file
        samples = read_waveform(500)
        if len(samples) >= 2:
            sample_buffer[:] = samples[-500:]

        # Draw waveform
        cw = wave_canvas.winfo_width()
        ch = wave_canvas.winfo_height()
        if cw < 10: cw = 800
        if ch < 10: ch = 200

        wave_canvas.delete('all')
        mid = ch / 2

        if len(sample_buffer) > 1:
            # Grid lines
            for y in range(0, ch, 20):
                wave_canvas.create_line(0, y, cw, y, fill='#1a3a5c', width=1)
            wave_canvas.create_line(0, mid, cw, mid, fill='#2a4a6c', width=1)

            # Waveform
            step = max(1, len(sample_buffer) // cw)
            pts = []
            for x in range(0, cw):
                idx = min(x * step, len(sample_buffer)-1)
                y = mid - sample_buffer[idx] * (ch/2 - 5)
                y = max(0, min(ch-1, y))
                pts.extend([x, y])
            if pts:
                wave_canvas.create_line(*pts, fill=ACCENT, width=2, smooth=True)

        # Peak marker
        peak = max(abs(s) for s in sample_buffer) if sample_buffer else 0
        wave_canvas.create_text(cw-60, 15, text=f"pk={peak:.2f}",
                                fill='#666', anchor='nw', font=('Consolas', 8))

    def update_status():
        packet_count[0] += 1
        pkts = packet_count[0]

        # Motor state (fake for now — would come from GET_STATUS)
        motor_states = ["■ STOPPED", "▶▶ FAST", "▶ PLAY", "◀◀ REW"]
        ms = motor_states[(pkts // 20) % 4]
        motor_lbl.config(text=f"MOTOR: {ms}")
        motor_lbl.config(fg=WARN if 'STOPPED' in ms else ACCENT)

        # Tape position from file size
        try:
            sz = os.path.getsize(TAPE_FILE) if os.path.exists(TAPE_FILE) else 0
            pos_mm = sz / 4 / (3200 / 47.6) if sz else 0
            pos_lbl.config(text=f"POS: {pos_mm:.0f} mm")
            tape_size_lbl.config(text=f"TAPE: {sz//1024} KB")

            # Tape bar
            tape_canvas.delete('all')
            tw = tape_canvas.winfo_width()
            if tw < 10: tw = 800
            frac = min(1.0, pos_mm / 90000)
            head_x = int(frac * (tw - 10)) + 5

            # Draw tape
            tape_canvas.create_line(5, 15, tw-5, 15, fill='#333', width=6)
            # Written portion
            written_x = int(frac * (tw - 10)) + 5
            tape_canvas.create_line(5, 15, written_x, 15, fill=ACCENT, width=6)
            # Head
            tape_canvas.create_rectangle(
                head_x-4, 8, head_x+4, 22, fill=WARN, outline='')
            # Labels
            tape_canvas.create_text(5, 25, text='BOT', fill='#666',
                                    anchor='nw', font=('Consolas', 7))
            tape_canvas.create_text(tw-5, 25, text='EOT', fill='#666',
                                    anchor='ne', font=('Consolas', 7))
            tape_canvas.create_text(tw//2, 3, text=f"{pos_mm:.0f} mm",
                                    fill=ACCENT, font=('Consolas', 8))

        except Exception:
            pass

        pkt_lbl.config(text=f"PACKETS: {pkts}")

        # Update files list every 20 frames
        if pkts % 20 == 0:
            try:
                file_listbox.delete(0, tk.END)
                from tapefs import Directory
                dir_, err = fs.list_files()
                if not err:
                    for e in dir_.entries:
                        file_listbox.insert(tk.END,
                            f"  {e.filename:<20} {e.file_size:>8} B")
            except:
                pass

        # Schedule next update (~30 FPS)
        root.after(33, update_status)

    def on_close():
        global ui_running
        ui_running = False
        root.destroy()

    root.protocol("WM_DELETE_WINDOW", on_close)

    # ---- Start FUSE in background thread ------------------------- #
    class TapeFS(fuse.Operations):
        def getattr(self, path, fh=None):
            st = fuse.Stat()
            st.st_mode = 0o755; st.st_nlink = 2
            if path == '/': st.st_mode = 0o755 | 0o40000; return st
            name = path.lstrip('/')
            from tapefs import Directory
            d, e = fs.list_files()
            if e: return -fuse.ENOENT
            for x in d.entries:
                if x.filename == name:
                    st.st_mode = 0o644 | 0o100000; st.st_nlink = 1
                    st.st_size = x.file_size; return st
            return -fuse.ENOENT
        def readdir(self, path, fh):
            yield '.'; yield '..'
            from tapefs import Directory
            d, e = fs.list_files()
            if not e:
                for x in d.entries: yield x.filename
        def open(self, path, flags): return 0
        def read(self, path, size, offset, fh):
            d, _ = fs.read_file(path.lstrip('/'))
            return (d or b'')[offset:offset+size]
        def write(self, path, data, offset, fh):
            name = path.lstrip('/')
            old, _ = fs.read_file(name)
            new = (old or b'')[:offset] + data + (old or b'')[offset+len(data):]
            fs.write_file(name, new); return len(data)
        def truncate(self, path, length, fh=None):
            name = path.lstrip('/')
            old, _ = fs.read_file(name)
            fs.write_file(name, (old or b'')[:length]); return 0
        def unlink(self, path):
            from tapefs import Directory
            d, e = fs.list_files()
            if not e: d.remove(path.lstrip('/')); fs.write_directory(d)
            return 0

    fuse_thread = threading.Thread(
        target=lambda: fuse.FUSE(TapeFS(), mountpoint, foreground=True,
                                 allow_other=False),
        daemon=True
    )
    fuse_thread.start()

    # ---- Start UI update loop ----------------------------------- #
    print(f"  Mounted at {mountpoint}")
    print(f"  Debug window open. Close window to unmount.")

    update_waveform()
    root.after(100, update_status)
    root.after(50, lambda: root.after(50, update_waveform()))

    # Schedule waveform updates at ~20 FPS
    def wave_loop():
        update_waveform()
        root.after(50, wave_loop)
    root.after(50, wave_loop)

    try:
        root.mainloop()
    except KeyboardInterrupt:
        pass
    finally:
        ui_running = False
        fw_stop()
        print("  Unmounted.")

# ---- Main --------------------------------------------------------- #
if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: tapeworm mount <folder> | format | ls | read | write")
        sys.exit(1)

    try:
        cmd = sys.argv[1]; args = sys.argv[2:]
        if cmd == 'format': cmd_format()
        elif cmd == 'ls': cmd_ls()
        elif cmd == 'read': cmd_read(args[0], args[1] if len(args)>1 else None)
        elif cmd == 'write': cmd_write(args[0], args[1] if len(args)>1 else None)
        elif cmd == 'mount': cmd_mount(args[0] if args else './tape_mount')
        else: print(f"Unknown: {cmd}")
    except KeyboardInterrupt:
        pass
    finally:
        fw_stop()
        print("\033[?25h\033[H\033[J", end='')
