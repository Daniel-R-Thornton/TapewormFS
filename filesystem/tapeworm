#!/usr/bin/env python3
"""
tapeworm — one command for the full tape pipeline.

  ./tapeworm mount <folder>    Mount as folder + debug UI
  ./tapeworm format            Format tape
  ./tapeworm ls                List files
  ./tapeworm read <n> [out]    Read file
  ./tapeworm write <l> [n]     Write file
"""

import os, sys, struct, time, select, subprocess, signal, atexit, threading, errno
import struct as st

HERE = os.path.dirname(os.path.abspath(__file__))
FW_BIN = os.path.join(HERE, "cpp", "firmware", "run_firmware")
TAPE_FILE = "/tmp/tapewormfs_raw.tape"

# Build firmware
if not os.path.exists(FW_BIN):
    fw_dir = os.path.join(HERE, "cpp", "firmware")
    subprocess.check_call(
        f"cd '{fw_dir}' && g++ -std=c++17 -o run_firmware -x c++ - <<< "
        f'#include "firmware.hpp"\n'
        f'int main() {{ tapefs::firmware::Firmware fw; fw.run(); return 0; }}'
        f' firmware.cpp modem_encoder.cpp modem_decoder.cpp '
        f'tape_medium.cpp tape_deck.cpp motor.cpp esp32_hal.cpp '
        f'-lpthread -I.', shell=True)

# ---- Packet protocol --------------------------------------------- #
START = 0xFE
def crc16(d):
    c = 0
    for b in d:
        c ^= b << 8
        for _ in range(8):
            if c & 0x8000: c = (c << 1) ^ 0x8005
            else: c <<= 1
            c &= 0xFFFF
    return c

def esc(d):
    o = bytearray()
    for b in d:
        if b == 0xFE: o.extend([0xFD, 0x01])
        elif b == 0xFD: o.extend([0xFD, 0x02])
        else: o.append(b)
    return bytes(o)

def unesc(d):
    o = bytearray(); i = 0
    while i < len(d):
        if d[i] == 0xFD and i+1 < len(d):
            if d[i+1] == 0x01: o.append(0xFE)
            elif d[i+1] == 0x02: o.append(0xFD)
            i += 2
        else: o.append(d[i]); i += 1
    return bytes(o)

def enc(c, p=b''):
    inner = st.pack('<H', 1+len(p)+2) + bytes([c]) + p
    crc = crc16(inner) & 0xFFFF
    inner += st.pack('<H', crc)
    return bytes([START]) + esc(inner)

def dec(data):
    if not data or data[0] != START: return None
    inner = unesc(data[1:])
    if len(inner) < 5: return None
    L = st.unpack_from('<H', inner, 0)[0]
    if len(inner) < 2+L: return None
    cmd = inner[2]
    payload = inner[3:3+L-3]
    return {'cmd': cmd, 'payload': payload}

# ---- Firmware process -------------------------------------------- #
fw = None

def fw_start():
    global fw
    if fw and fw.poll() is None: return
    fw = subprocess.Popen([FW_BIN], stdin=subprocess.PIPE,
                          stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    time.sleep(0.3)
    atexit.register(fw_stop)

def fw_stop():
    global fw
    if fw:
        try: fw.terminate(); fw.wait(timeout=2)
        except: fw.kill()
        fw = None

def send(c, p=b''):
    fw_start(); fw.stdin.write(enc(c, p)); fw.stdin.flush()

def recv(e, t=5.0):
    buf = b''; dl = time.monotonic() + t
    while time.monotonic() < dl:
        r,_,_ = select.select([fw.stdout],[],[],0.1)
        if r:
            c = fw.stdout.read1(4096)
            if not c: return None
            buf += c
        i = buf.find(bytes([START]))
        if i < 0: continue
        buf = buf[i:]
        pk = dec(buf)
        if pk is None: buf = buf[1:]; continue
        if pk['cmd'] == e: return pk['payload']
        buf = b''
    return None

def wb(block_bytes):
    send(0x05, block_bytes)
    r = recv(0x85)
    if r and r[0] == 0x00:
        send(0x07); recv(0x87)
        return True
    return False

def rb():
    send(0x06)
    r = recv(0x86, 120.0)
    if r and len(r) > 5: return r[0:1] + r[1:-4]
    return None

def sk(n):
    p = st.pack('<III', n, 0, n*1000) + bytes([0, 255])
    send(0x03, p); r = recv(0x83)
    return r and r[0] == 0x00

# ---- Read waveform from tape file -------------------------------- #
def read_waveform(count=320):
    """Read last N float32 samples from the tape file."""
    if not os.path.exists(TAPE_FILE): return [0.0]*count
    with open(TAPE_FILE, 'rb') as f:
        f.seek(0, 2)  # end
        sz = f.tell()
        samples = min(count, sz // 4)
        f.seek(max(0, sz - samples*4))
        raw = f.read(samples*4)
    return [st.unpack_from('<f', raw, i)[0] for i in range(0, len(raw), 4)]

# ---- Commands ----------------------------------------------------- #
def cmd_format():
    from tapefs import Block, BlockType, serialise, Directory
    d = serialise(Block(BlockType.DIRECTORY, data=Directory().serialise()))
    e = serialise(Block(BlockType.EOT, seq_no=1))
    if wb(d.bytes) and wb(e.bytes): print("  Tape formatted")
    else: print("  Format failed")
    fw_stop()

def cmd_ls():
    from tapefs import deserialise, RawBlock, Directory
    if not sk(0): return print("  (empty tape)")
    rd = rb()
    if not rd: return print("  (empty tape)")
    b, e = deserialise(RawBlock(bytes=rd))
    if e or b.type != 2: return print("  (empty tape)")
    d = Directory.deserialise(b.data)
    if not d.entries: return print("  (empty tape)")
    for e in d.entries: print(f"  {e.filename:<20} {e.file_size:>8} B")
    fw_stop()

def cmd_read(name, out=None):
    from tapefs import Filesystem, RawBlock
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)
    data, err = fs.read_file(name)
    if err: return print(f"  '{name}' not found")
    if out:
        with open(out, 'wb') as f: f.write(data)
        print(f"  Wrote {len(data)} B to {out}")
    else: sys.stdout.buffer.write(data)
    fw_stop()

def cmd_write(local, tapename=None):
    tapename = tapename or os.path.basename(local)
    with open(local, 'rb') as f: data = f.read()
    from tapefs import Filesystem, RawBlock
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)
    err = fs.write_file(tapename, data)
    if err: return print(f"  Write failed: {err}")
    print(f"  Wrote '{tapename}' ({len(data)} B)")
    fw_stop()

def cmd_mount(mountpoint):
    """Mount FUSE folder with live status file + background cache."""
    import fuse

    fw_start()
    from tapefs import Filesystem, RawBlock, Directory
    fs = Filesystem(wb, lambda: RawBlock(bytes=rb()) if rb() else None, sk)

    # ---- Status + directory cache (never blocks FUSE) ---------- #
    status = {'text': 'LOADING...', 'pct': 0}
    dir_cache = []

    def bg_loop():
        """Background: read tape directory, update cache."""
        while True:
            try:
                d, err = fs.list_files()
                if not err:
                    dir_cache[:] = [(x.filename, x.file_size) for x in d.entries]
                    status['text'] = f'IDLE  ({len(dir_cache)} files)'
                    status['pct'] = 100
                else:
                    status['text'] = f'SCANNING...'
                    status['pct'] = int(time.monotonic() * 10) % 100
            except:
                status['text'] = 'ERROR'
            time.sleep(5)

    threading.Thread(target=bg_loop, daemon=True).start()

    # ---- FUSE operations (instant, from cache only) ------------- #
    class TapeFS(fuse.Operations):
        def getattr(self, path, fh=None):
            if path == '/':
                return {'st_mode': 0o755 | 0o40000, 'st_nlink': 2}
            name = path.lstrip('/')
            if name == '_tape_status.txt':
                return {'st_mode': 0o644 | 0o100000, 'st_nlink': 1,
                        'st_size': len(status['text'])}
            for fn, sz in dir_cache:
                if fn == name:
                    return {'st_mode': 0o644 | 0o100000, 'st_nlink': 1, 'st_size': sz}
            raise fuse.FuseOSError(errno.ENOENT)
        def readdir(self, path, fh=None):
            yield '.'; yield '..'
            yield '_tape_status.txt'
            for fn, _ in dir_cache:
                yield fn
        def read(self, path, size, offset, fh):
            name = path.lstrip('/')
            if name == '_tape_status.txt':
                return status['text'].encode()[offset:offset+size]
            d, _ = fs.read_file(name)
            return (d or b'')[offset:offset+size]
        def write(self, path, data, offset, fh):
            name = path.lstrip('/')
            if name == '_tape_status.txt': return len(data)
            old, _ = fs.read_file(name)
            new = (old or b'')[:offset] + data + (old or b'')[offset+len(data):]
            fs.write_file(name, new)
            return len(data)
        def truncate(self, path, length, fh=None):
            name = path.lstrip('/')
            old, _ = fs.read_file(name) or b''
            fs.write_file(name, old[:length])
            return 0
        def unlink(self, path):
            d, e = fs.list_files()
            if not e: d.remove(path.lstrip('/')); fs.write_directory(d)
            return 0

    # ---- Start FUSE in background + keep running ------------- #
    try:
        os.makedirs(mountpoint, exist_ok=True)
        abspath = os.path.abspath(mountpoint)
        print(f"  Mounted at {abspath}")
        print(f"  cat {abspath}/_tape_status.txt  to see status")
        
        def run_fuse():
            try:
                fuse.FUSE(TapeFS(), abspath, foreground=True)
            except:
                pass
        threading.Thread(target=run_fuse, daemon=True).start()
        time.sleep(0.5)
        
        # Keep alive until Ctrl+C
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        pass
    except Exception as e:
        print(f"  Error: {e}")
    finally:
        fw_stop()
        print("  Unmounted.")
