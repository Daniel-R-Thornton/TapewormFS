#!/usr/bin/env python3
"""
tapeworm — one command for the full tape pipeline.

  ./tapeworm mount <folder>    Mount as folder + debug UI
  ./tapeworm format            Format tape
  ./tapeworm ls                List files
  ./tapeworm read <n> [out]    Read file
  ./tapeworm write <l> [n]     Write file
"""

import os, sys, struct, time, select, subprocess, signal, atexit, threading, errno
import struct as st


# ---- Debug logging to /tmp/tapewormfs_debug.log ---------------- #
_log_file = None
def log_init():
    global _log_file
    if _log_file is None:
        _log_file = open('/tmp/tapewormfs_debug.log', 'a')
        _log_file.write(f"\n=== TapewormFS {__import__('datetime').datetime.now()} ===\n")
        _log_file.flush()
def log(msg, *args):
    log_init()
    import datetime
    t = datetime.datetime.now().strftime('%H:%M:%S.%f')[:12]
    _log_file.write(f"[{t}] {msg}\n")
    if args:
        for a in args: _log_file.write(f"  {a}\n")
    _log_file.flush()

import atexit
@atexit.register
def _log_close():
    global _log_file
    if _log_file:
        _log_file.write("=== END ===\n\n")
        _log_file.close()
        _log_file = None
HERE = os.path.dirname(os.path.abspath(__file__))
FW_BIN = os.path.join(HERE, "cpp", "firmware", "run_firmware")
TAPE_FILE = "/tmp/tapewormfs_raw.tape"

# Build firmware
if not os.path.exists(FW_BIN):
    fw_dir = os.path.join(HERE, "cpp", "firmware")
    subprocess.check_call(
        f"cd '{fw_dir}' && g++ -std=c++17 -o run_firmware -x c++ - <<< "
        f'#include "firmware.hpp"\n'
        f'int main() {{ tapefs::firmware::Firmware fw; fw.run(); return 0; }}'
        f' firmware.cpp modem_encoder.cpp modem_decoder.cpp '
        f'tape_medium.cpp tape_deck.cpp motor.cpp esp32_hal.cpp '
        f'-lpthread -I.', shell=True)

# ---- Packet protocol --------------------------------------------- #
START = 0xFE
def crc16(d):
    c = 0
    for b in d:
        c ^= b << 8
        for _ in range(8):
            if c & 0x8000: c = (c << 1) ^ 0x8005
            else: c <<= 1
            c &= 0xFFFF
    return c

def esc(d):
    o = bytearray()
    for b in d:
        if b == 0xFE: o.extend([0xFD, 0x01])
        elif b == 0xFD: o.extend([0xFD, 0x02])
        else: o.append(b)
    return bytes(o)

def unesc(d):
    o = bytearray(); i = 0
    while i < len(d):
        if d[i] == 0xFD and i+1 < len(d):
            if d[i+1] == 0x01: o.append(0xFE)
            elif d[i+1] == 0x02: o.append(0xFD)
            i += 2
        else: o.append(d[i]); i += 1
    return bytes(o)

def enc(c, p=b''):
    inner = st.pack('<H', 1+len(p)+2) + bytes([c]) + p
    crc = crc16(inner) & 0xFFFF
    inner += st.pack('<H', crc)
    return bytes([START]) + esc(inner)

def dec(data):
    if not data or data[0] != START: return None
    inner = unesc(data[1:])
    if len(inner) < 5: return None
    L = st.unpack_from('<H', inner, 0)[0]
    if len(inner) < 2+L: return None
    cmd = inner[2]
    payload = inner[3:3+L-3]
    return {'cmd': cmd, 'payload': payload}

# ---- Firmware process -------------------------------------------- #
fw = None

def fw_start():
    global fw
    if fw and fw.poll() is None: return
    fw = subprocess.Popen([FW_BIN], stdin=subprocess.PIPE,
                          stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    time.sleep(0.3)
    atexit.register(fw_stop)

def fw_stop():
    global fw
    if fw:
        try: fw.terminate(); fw.wait(timeout=2)
        except: fw.kill()
        fw = None

def send(c, p=b''):
    log(f'UART TX: cmd=0x{c:02x} len={len(p)}')
    fw_start(); fw.stdin.write(enc(c, p)); fw.stdin.flush()

def recv(e, t=5.0):
    log(f'UART RX: wait cmd=0x{e:02x} timeout={t}s')
    buf = b''; dl = time.monotonic() + t
    while time.monotonic() < dl:
        r,_,_ = select.select([fw.stdout],[],[],0.1)
        if r:
            c = fw.stdout.read1(4096)
            if not c: return None
            buf += c
        i = buf.find(bytes([START]))
        if i < 0: continue
        buf = buf[i:]
        pk = dec(buf)
        if pk is None: buf = buf[1:]; continue
        if pk['cmd'] == e:
            log(f'UART RX: got cmd=0x{e:02x} len={len(pk["payload"])}')
            return pk['payload']
        buf = b''
    return None

def wb(block):
    """Write a RawBlock to the firmware."""
    from tapefs import RawBlock
    if isinstance(block, RawBlock):
        data = block.bytes
    else:
        data = block
    send(0x05, data)
    r = recv(0x85)
    if r and r[0] == 0x00:
        send(0x07); recv(0x87)
        return True
    return False

def rb_fast(timeout=3.0):
    send(0x06)
    r = recv(0x86, timeout)
    if r and len(r) > 5: return r[0:1] + r[1:-4]
    return None

def rb():
    send(0x06)
    r = recv(0x86, 120.0)
    if r and len(r) > 5: return r[0:1] + r[1:-4]
    return None

def sk_fast(n, timeout=2.0):
    p = st.pack("<III", n, 0, n*1000) + bytes([0, 255])
    send(0x03, p); r = recv(0x83, timeout)
    return r and r[0] == 0x00

def sk(n):
    p = st.pack('<III', n, 0, n*1000) + bytes([0, 255])
    send(0x03, p); r = recv(0x83)
    return r and r[0] == 0x00

# ---- Read waveform from tape file -------------------------------- #
def read_waveform(count=320):
    """Read last N float32 samples from the tape file."""
    if not os.path.exists(TAPE_FILE): return [0.0]*count
    with open(TAPE_FILE, 'rb') as f:
        f.seek(0, 2)  # end
        sz = f.tell()
        samples = min(count, sz // 4)
        f.seek(max(0, sz - samples*4))
        raw = f.read(samples*4)
    return [st.unpack_from('<f', raw, i)[0] for i in range(0, len(raw), 4)]

# ---- Commands ----------------------------------------------------- #
def cmd_format():
    from tapefs import Block, BlockType, serialise, Directory
    d = serialise(Block(BlockType.DIRECTORY, data=Directory().serialise()))
    e = serialise(Block(BlockType.EOT, seq_no=1))
    if wb(d.bytes) and wb(e.bytes): print("  Tape formatted")
    else: print("  Format failed")
    fw_stop()

def cmd_ls():
    from tapefs import deserialise, RawBlock, Directory
    if not sk(0): return print("  (empty tape)")
    rd = rb()
    if not rd: return print("  (empty tape)")
    b, e = deserialise(RawBlock(bytes=rd))
    if e or b.type != 2: return print("  (empty tape)")
    d = Directory.deserialise(b.data)
    if not d.entries: return print("  (empty tape)")
    for e in d.entries: print(f"  {e.filename:<20} {e.file_size:>8} B")
    fw_stop()

def cmd_read(name, out=None):
    from tapefs import Filesystem, RawBlock
    fs_mount = Filesystem(wb, lambda: (lambda r: RawBlock(bytes=r) if r else None)(rb_fast()), lambda n: sk_fast(n))
    data, err = fs_mount.read_file(name)
    if err: return print(f"  '{name}' not found")
    if out:
        with open(out, 'wb') as f: f.write(data)
        print(f"  Wrote {len(data)} B to {out}")
    else: sys.stdout.buffer.write(data)
    fw_stop()

def cmd_write(local, tapename=None):
    tapename = tapename or os.path.basename(local)
    with open(local, 'rb') as f: data = f.read()
    from tapefs import Filesystem, RawBlock
    fs_mount = Filesystem(wb, lambda: (lambda r: RawBlock(bytes=r) if r else None)(rb_fast()), lambda n: sk_fast(n))
    err = fs_mount.write_file(tapename, data)
    if err: return print(f"  Write failed: {err}")
    print(f"  Wrote '{tapename}' ({len(data)} B)")
    fw_stop()

def cmd_mount(mountpoint):
    """Mount FUSE folder with live status file + debug UI."""
    print("  Starting firmware...", flush=True)
    import fuse

    fw_start()
    print("  Setting up filesystem...", flush=True)
    from tapefs import Filesystem, RawBlock, Directory
    fs_mount = Filesystem(wb, lambda: (lambda r: RawBlock(bytes=r) if r else None)(rb_fast()), lambda n: sk_fast(n))

    # ---- Status + directory cache + pending writes ------------ #
    status = {'text': 'LOADING...'}
    dir_cache = []        # from tape: [(name, size)]
    pending = {}          # written but not synced: {name: bytes}

    def sync_pending():
        log('SYNC thread started')
        """Background: write pending files to tape, update dir cache."""
        while True:
            try:
                # Read current tape directory
                d, err = fs_mount.list_files()
                if not err:
                    dir_cache[:] = [(x.filename, x.file_size) for x in d.entries]
                
                # Flush pending writes to tape
                for name, data in list(pending.items()):
                    log(f'SYNC writing {name} ({len(data)} bytes)')
                    err = fs_mount.write_file(name, data)
                    if not err:
                        dir_cache.append((name, len(data)))
                        del pending[name]
                        status['text'] = f'SYNCED {name}'
                        log(f'SYNC done: {name}')
                    else:
                        status['text'] = f'ERROR syncing {name}'
                
                if not pending:
                    status['text'] = f'IDLE  ({len(dir_cache)} files)'
                    log(f'SYNC idle: {len(dir_cache)} files, {len(pending)} pending')
            except Exception as e:
                import traceback
                import sys
                tb = traceback.format_exc()
                status['text'] = f'ERROR: {e}'
                log(f'SYNC error: {e}', tb)
            time.sleep(5)

    threading.Thread(target=sync_pending, daemon=True).start()

    # ---- Combine tape + pending for FUSE lookups -------------- #
    def all_files():
        """Return list of (name, size) from both tape and pending."""
        seen = set()
        result = []
        result.append(('_tape_status.txt', len(status['text'])))
        seen.add('_tape_status.txt')
        for name, data in pending.items():
            result.append((name, len(data)))
            seen.add(name)
        for fn, sz in dir_cache:
            if fn not in seen:
                result.append((fn, sz))
                seen.add(fn)
        return result

    def exists(name):
        return any(fn == name for fn, _ in all_files())

    def get_data(name):
        """Return file data from pending cache or tape dir cache."""
        if name == '_tape_status.txt':
            return status['text'].encode()
        if name in pending:
            return pending[name]
        # Not in pending — try cached tape data
        for fn, _ in dir_cache:
            if fn == name:
                # Queue a background read (placeholder, returns empty for now)
                return b''
        return b''
        """Return file data from pending cache or tape."""
        if name == '_tape_status.txt':
            return status['text'].encode()
        if name in pending:
            return pending[name]
        d, _ = fs_mount.read_file(name)
        return d or b''

    # ---- FUSE operations (instant, from cache + pending) ------ #
    class TapeFS(fuse.Operations):
        def access(self, path, amode):
            log(f'FUSE access: {path} mode={amode}')
            return 0
        def getattr(self, path, fh=None):
            log(f'FUSE getattr: {path}')
            if path == '/':
                return {'st_mode': 0o755 | 0o40000, 'st_nlink': 2,
                        'st_uid': os.getuid(), 'st_gid': os.getgid()}
            name = path.lstrip('/')
            for fn, sz in all_files():
                if fn == name:
                    return {'st_mode': 0o644 | 0o100000, 'st_nlink': 1,
                            'st_size': sz, 'st_uid': os.getuid(), 'st_gid': os.getgid()}
            raise fuse.FuseOSError(errno.ENOENT)
        def readdir(self, path, fh=None):
            log(f'FUSE readdir: {path}')
            yield '.'; yield '..'
            for fn, _ in all_files():
                yield fn
        def read(self, path, size, offset, fh):
            name = path.lstrip('/')
            log(f'FUSE read: {name} offset={offset} size={size}')
            data = get_data(name)
            return data[offset:offset+size]
        def create(self, path, mode):
            name = path.lstrip('/')
            log(f'FUSE create: {name}')
            if name not in pending:
                pending[name] = b''
            return hash(name) & 0xFFFFFFFF
        def open(self, path, flags):
            name = path.lstrip('/')
            log(f'FUSE open: {name}')
            if not exists(name):
                pending[name] = b''
            return hash(name) & 0xFFFFFFFF
        def write(self, path, data, offset, fh):
            name = path.lstrip('/')
            log(f'FUSE write: {name} offset={offset} size={len(data)}')
            if name == '_tape_status.txt': return len(data)
            old = pending.get(name, get_data(name))
            new = old[:offset] + data + old[offset+len(data):]
            pending[name] = new
            return len(data)
        def truncate(self, path, length, fh=None):
            name = path.lstrip('/')
            log(f'FUSE truncate: {name} len={length}')
            old = pending.get(name, get_data(name))
            pending[name] = old[:length]
            return 0
        def ftruncate(self, path, length, fh):
            return self.truncate(path, length)
        def flush(self, path, fh): return 0
        def release(self, path, fh): return 0
        def fsync(self, path, datasync, fh): return 0
        def unlink(self, path):
            name = path.lstrip('/')
            log(f'FUSE unlink: {name}')
            pending.pop(name, None)
            # Mark for deletion in dir_cache — sync thread handles tape
            return 0

    # ---- Start FUSE in background ----------------------------- #
    try:
        os.makedirs(mountpoint, exist_ok=True)
        abspath = os.path.abspath(mountpoint)
        print(f"  Mounted at {abspath}")
        
        def run_fuse():
            try:
                fuse.FUSE(TapeFS(), abspath, foreground=True, nonempty=True)
            except:
                pass
        threading.Thread(target=run_fuse, daemon=True).start()
        time.sleep(0.5)
        
        # ---- tkinter debug window ------------------------------- #
        import tkinter as tk
        root = tk.Tk()
        root.title("TapewormFS — Live Debug")
        root.geometry("900x600")
        root.configure(bg='#1a1a2e')
        root.attributes("-topmost", True)
        
        BG = '#1a1a2e'; FG = '#e0e0e0'; ACCENT = '#00d4aa'
        WAVE_BG = '#16213e'
        
        # Waveform canvas
        wave_canvas = tk.Canvas(root, bg=WAVE_BG, height=200, highlightthickness=0)
        wave_canvas.pack(fill=tk.BOTH, expand=True, padx=10, pady=5)
        
        # Tape position bar
        tape_canvas = tk.Canvas(root, bg='#0f3460', height=30, highlightthickness=0)
        tape_canvas.pack(fill=tk.X, padx=10, pady=2)
        
        # Info row
        info = tk.Frame(root, bg=BG)
        info.pack(fill=tk.X, padx=10, pady=5)
        motor_lbl = tk.Label(info, text="MOTOR: ■ STOPPED", fg='#ff6b6b', bg=BG, font=('Consolas',11))
        motor_lbl.pack(side=tk.LEFT, padx=10)
        pkt_lbl = tk.Label(info, text="PACKETS: 0", fg=FG, bg=BG, font=('Consolas',11))
        pkt_lbl.pack(side=tk.LEFT, padx=10)
        pos_lbl = tk.Label(info, text="POS: 0 mm", fg=FG, bg=BG, font=('Consolas',11))
        pos_lbl.pack(side=tk.RIGHT, padx=10)
        
        # Waveform reader
        def read_wave():
            """Read audio samples from the tape file."""
            path = "/tmp/tapewormfs_raw.tape"
            if not os.path.exists(path): return []
            try:
                sz = os.path.getsize(path)
                n = sz // 4
                if n < 100: return []
                # Read last ~500ms of audio (1600 samples at 3200 Hz)
                # Skip the final guard silence — look for signal
                count = min(1600, n)
                with open(path, 'rb') as f:
                    f.seek(-count*4, 2)
                    raw = f.read(count*4)
                samples = [__import__('struct').unpack_from('<f',raw,i)[0] for i in range(0,len(raw),4)]
                # Find the last peak in the window
                return samples
            except:
                return []
        
        def redraw():
            cw = wave_canvas.winfo_width() or 800
            ch = wave_canvas.winfo_height() or 200
            mid = ch/2
            wave_canvas.delete('all')
            for y in range(0,ch,20):
                wave_canvas.create_line(0,y,cw,y,fill='#1a3a5c',width=1)
            wave_canvas.create_line(0,mid,cw,mid,fill='#2a4a6c',width=1)
            
            samples = read_wave()
            log(f'WAVE: {len(samples)} samples')
            if len(samples)>100:
                # Use last 400 samples for display (skip initial tail)
                display = samples[-400:]
                step = max(1, len(display)//cw)
                pts = []
                for x in range(cw):
                    idx = min(x*step, len(display)-1)
                    y = mid - display[idx]*(ch/2-5)
                    pts.extend([x, max(0,min(ch-1,y))])
                if pts: wave_canvas.create_line(*pts, fill=ACCENT, width=2, smooth=True)
            
            # Tape bar
            tw = tape_canvas.winfo_width() or 800
            tape_canvas.delete('all')
            try:
                sz = os.path.getsize("/tmp/tapewormfs_raw.tape")
                pos_mm = sz/4/(3200/47.6) if sz else 0
                frac = min(1.0, pos_mm/90000)
                hx = int(frac*(tw-10))+5
                tape_canvas.create_line(5,15,tw-5,15,fill='#333',width=6)
                tape_canvas.create_line(5,15,hx,15,fill=ACCENT,width=6)
                tape_canvas.create_rectangle(hx-4,8,hx+4,22,fill='#ff6b6b',outline='')
                pos_lbl.config(text=f"POS: {pos_mm:.0f} mm")
            except: pass
            
            # Status from real background sync
            txt = status.get('text', 'LOADING...')
            pkt_lbl.config(text=f"{txt}")
            
            # Motor state from status
            if 'SYNC' in txt or 'WRIT' in txt:
                motor_lbl.config(text='MOTOR: ▶▶ FAST', fg=ACCENT)
            elif 'IDLE' in txt:
                motor_lbl.config(text='MOTOR: ■ STOPPED', fg='#ff6b6b')
            elif 'LOAD' in txt or 'SCAN' in txt:
                motor_lbl.config(text='MOTOR: ◀◀ REW', fg='#ffaa00')
            else:
                motor_lbl.config(text=f'MOTOR: {txt}', fg='#888')
            
            # File count
            n_tape = len(dir_cache)
            n_pend = len(pending)
            if n_pend:
                pkt_lbl.config(text=f"WRITING ({n_pend} pending, {n_tape} on tape)")
            
            root.after(100, redraw)
        
        root.after(100, redraw)
        root.mainloop()
        
    except KeyboardInterrupt:
        pass
    except Exception as e:
        print(f"  Error: {e}")
    finally:
        fw_stop()
        print("  Unmounted.")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: tapeworm mount <folder> | format | ls | read | write")
        sys.exit(1)

    try:
        cmd = sys.argv[1]; args = sys.argv[2:]
        if cmd == 'format': cmd_format()
        elif cmd == 'ls': cmd_ls()
        elif cmd == 'read': cmd_read(args[0], args[1] if len(args)>1 else None)
        elif cmd == 'write': cmd_write(args[0], args[1] if len(args)>1 else None)
        elif cmd == 'mount': cmd_mount(args[0] if args else './tape_mount')
        else: print(f"Unknown: {cmd}")
    except KeyboardInterrupt:
        pass
    finally:
        fw_stop()
